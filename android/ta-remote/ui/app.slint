// Bundle a monospace font with broad Unicode coverage plus a monochrome
// emoji font, since Android's "monospace" alias (DroidSans/RobotoMono)
// has neither extended Latin nor pictographs — emojis show as tofu and
// accented chars in tab previews/output go missing. FreeMono covers the
// Miscellaneous Technical block (U+23xx) used by TUIs like Claude Code
// for double-arrows and tree connectors that DejaVu Sans Mono lacks.
import "../fonts/FreeMono.ttf";
import "../fonts/NotoEmoji.ttf";

struct TabRow {
    name: string,
    cwd: string,
    active: bool,
    cpu: string,
    preview: string,
    /// Pre-formatted active-time counter ("1h 02m", "37m 12s", …) sourced
    /// from the desktop's per-tab uptime so the phone shows the same
    /// clock without running its own timer.
    uptime: string,
    /// Set when the preview text has changed since the user last opened
    /// this tab — used to surface "this tab moved" without having to open it.
    has-new: bool,
}

// One contiguous run of same-colour glyphs in a terminal row. Built on
// the Rust side from the ANSI SGR sequences in /tabs/N/output so the
// renderer can compose colourised lines without a Slint-side parser.
struct ColorSpan {
    text: string,
    color: color,
    bold: bool,
}

struct ColorLine {
    spans: [ColorSpan],
}

struct Host {
    name: string,
    reachability: string,    // "lan" | "remote" | "offline"
    detail: string,          // shown next to the badge
    url: string,             // LAN URL
    remote-url: string,      // optional remote URL
    token: string,
}

component HeaderBar inherits Rectangle {
    in property <string> host-name;
    in property <string> reachability;
    in property <string> detail;
    in property <bool> multi-host;
    callback host-tap();
    callback add-host-tap();

    height: 64px;
    background: #181818;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 12px;
        alignment: stretch;

        TouchArea {
            enabled: root.multi-host;
            clicked => { root.host-tap() }
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: root.host-name;
                            color: #e0e0e0;
                            font-size: 18px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        if root.multi-host : Rectangle {
                            width: 18px;
                            height: 18px;
                            y: parent.height / 2 - 9px;
                            Path {
                                viewbox-width: 24;
                                viewbox-height: 24;
                                fill: #888;
                                commands: "M 7 10 L 12 15 L 17 10 Z";
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: root.reachability == "lan" ? #66bb6a
                                : root.reachability == "remote" ? #ffa726
                                : root.reachability == "connecting" ? #aaaaaa
                                : #ef5350;
                            y: parent.height / 2 - 4px;
                        }
                        Text {
                            text: (root.reachability == "lan" ? "LAN · "
                                : root.reachability == "remote" ? "Remote · "
                                : root.reachability == "connecting" ? "Connecting · "
                                : "Offline · ") + root.detail;
                            color: root.reachability == "lan" ? #66bb6a
                                : root.reachability == "remote" ? #ffa726
                                : root.reachability == "connecting" ? #aaaaaa
                                : #ef5350;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle { horizontal-stretch: 1; }

        TouchArea {
            width: 44px;
            clicked => { root.add-host-tap() }
            Rectangle {
                background: parent.has-hover ? #2a2a2a : transparent;
                border-radius: 6px;
                Text {
                    text: "+";
                    color: #e0e0e0;
                    font-size: 26px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

component TabCard inherits Rectangle {
    in property <TabRow> tab;
    callback tapped();
    callback actions-requested();

    height: 96px;
    background: ta.has-hover ? #232323 : #1e1e1e;
    border-radius: 8px;
    border-width: 1px;
    border-color: tab.active ? #4a8cff : #2a2a2a;

    HorizontalLayout {
        padding: 0;
        spacing: 0;

        ta := TouchArea {
            horizontal-stretch: 1;
            clicked => { root.tapped() }

            HorizontalLayout {
                padding: 12px;
                spacing: 12px;

                Rectangle {
                    width: 8px;
                    background: tab.active ? #4a8cff : #555;
                    border-radius: 4px;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 3px;

                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Text {
                            text: tab.name;
                            color: #f0f0f0;
                            font-size: 16px;
                            font-weight: 600;
                            overflow: elide;
                        }
                        if tab.has-new : Rectangle {
                            width: 8px;
                            height: 8px;
                            y: parent.height / 2 - 4px;
                            border-radius: 4px;
                            background: #66bb6a;
                        }
                    }
                    Text {
                        text: tab.cwd;
                        color: #888;
                        font-size: 12px;
                        overflow: elide;
                    }
                    Text {
                        text: tab.preview;
                        color: #6b8caf;
                        font-size: 11px;
                        font-family: "FreeMono";
                        overflow: elide;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    Text {
                        text: tab.cpu;
                        color: #aaa;
                        font-size: 12px;
                        horizontal-alignment: right;
                    }
                    Text {
                        text: tab.uptime;
                        color: #888;
                        font-size: 11px;
                        horizontal-alignment: right;
                    }
                    Text {
                        text: tab.active ? "active" : "";
                        color: #4a8cff;
                        font-size: 11px;
                        horizontal-alignment: right;
                    }
                }
            }
        }

        // Rename + Close moved into an action sheet behind this menu
        // button — on mobile the user rarely needs them and the inline
        // icons left less room for the tab name / preview.
        TouchArea {
            width: 36px;
            clicked => { root.actions-requested() }
            Rectangle {
                background: parent.has-hover ? #2a2a2a : transparent;
                border-radius: 6px;
                // Material `more-vert` (three dots).
                Path {
                    width: 18px;
                    height: 18px;
                    x: parent.width / 2 - 9px;
                    y: parent.height / 2 - 9px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: #888;
                    commands: "M 12 8 C 13.1 8 14 7.1 14 6 C 14 4.9 13.1 4 12 4 C 10.9 4 10 4.9 10 6 C 10 7.1 10.9 8 12 8 Z M 12 10 C 10.9 10 10 10.9 10 12 C 10 13.1 10.9 14 12 14 C 13.1 14 14 13.1 14 12 C 14 10.9 13.1 10 12 10 Z M 12 16 C 10.9 16 10 16.9 10 18 C 10 19.1 10.9 20 12 20 C 13.1 20 14 19.1 14 18 C 14 16.9 13.1 16 12 16 Z";
                }
            }
        }
    }
}

component HostRow inherits Rectangle {
    in property <Host> host;
    in property <bool> selected;
    callback tapped();
    callback edited();
    callback removed();

    height: 64px;
    background: ta.has-hover ? #2a2a2a : transparent;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 4px;
        spacing: 12px;

        ta := TouchArea {
            horizontal-stretch: 1;
            clicked => { root.tapped() }

            HorizontalLayout {
                spacing: 12px;

                Rectangle {
                    width: 10px;
                    background: host.reachability == "lan" ? #66bb6a
                        : host.reachability == "remote" ? #ffa726
                        : host.reachability == "connecting" ? #aaaaaa
                        : #ef5350;
                    border-radius: 5px;
                    y: parent.height / 2 - self.height / 2;
                    height: 10px;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 2px;
                    Text {
                        text: host.name;
                        color: #f0f0f0;
                        font-size: 15px;
                        font-weight: 600;
                    }
                    Text {
                        text: host.detail;
                        color: #888;
                        font-size: 12px;
                    }
                }

                Rectangle {
                    width: 24px;
                    if root.selected : Path {
                        width: 24px;
                        height: 24px;
                        x: parent.width / 2 - 12px;
                        y: parent.height / 2 - 12px;
                        viewbox-width: 24;
                        viewbox-height: 24;
                        fill: #4a8cff;
                        commands: "M 9 16.17 L 4.83 12 L 3.41 13.41 L 9 19 L 21 7 L 19.59 5.59 Z";
                    }
                }
            }
        }

        TouchArea {
            width: 36px;
            clicked => { root.edited() }
            Rectangle {
                background: parent.has-hover ? #2a2a2a : transparent;
                border-radius: 6px;
                // Material `edit` (pencil)
                Path {
                    width: 20px;
                    height: 20px;
                    x: parent.width / 2 - 10px;
                    y: parent.height / 2 - 10px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: #aaaaaa;
                    commands: "M 3 17.25 L 3 21 L 6.75 21 L 17.81 9.94 L 14.06 6.19 L 3 17.25 Z M 20.71 7.04 C 21.1 6.65 21.1 6.02 20.71 5.63 L 18.37 3.29 C 17.98 2.9 17.35 2.9 16.96 3.29 L 15.13 5.12 L 18.88 8.87 L 20.71 7.04 Z";
                }
            }
        }

        TouchArea {
            width: 36px;
            clicked => { root.removed() }
            Rectangle {
                background: parent.has-hover ? #3a1f1f : transparent;
                border-radius: 6px;
                Path {
                    width: 20px;
                    height: 20px;
                    x: parent.width / 2 - 10px;
                    y: parent.height / 2 - 10px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: #ef5350;
                    commands: "M 19 6.41 L 17.59 5 L 12 10.59 L 6.41 5 L 5 6.41 L 10.59 12 L 5 17.59 L 6.41 19 L 12 13.41 L 17.59 19 L 19 17.59 L 13.41 12 Z";
                }
            }
        }
    }
}

component HostEditor inherits Rectangle {
    in property <length> safe-top;
    in property <length> ime-height;
    in property <bool> editing;
    in-out property <string> name-text;
    in-out property <string> url-text;
    in-out property <string> remote-url-text;
    in-out property <string> token-text;
    in-out property <string> error;
    callback save(string, string, string, string);
    callback dismiss();

    background: #000000aa;

    TouchArea {
        clicked => { root.dismiss() }
    }

    Rectangle {
        width: min(parent.width * 88%, 480px);
        height: root.error == "" ? 440px : 472px;
        background: #1c1c1c;
        border-radius: 14px;
        border-width: 1px;
        border-color: #2a2a2a;
        // Slide the dialog up when the IME is open so the Save/Cancel
        // row stays above the keyboard. When closed, anchor to the top
        // safe area as before.
        y: root.ime-height > 0px
            ? max(root.safe-top + 8px, parent.height - root.ime-height - self.height - 8px)
            : root.safe-top + 24px;

        VerticalLayout {
            padding: 0;
            spacing: 0;

            Rectangle {
                height: 48px;
                background: #232323;
                border-top-left-radius: 14px;
                border-top-right-radius: 14px;
                Text {
                    text: root.editing ? "Edit workstation" : "Add workstation";
                    color: #e0e0e0;
                    font-size: 16px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text { text: "Name"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.name-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }

                Text { text: "LAN URL (http://192.168.x.x:7890)"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.url-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }

                Text { text: "Remote URL (optional)"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.remote-url-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }

                Text { text: "Token"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.token-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }
                if root.error != "" : Text {
                    text: root.error;
                    color: #ef5350;
                    font-size: 12px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }

            HorizontalLayout {
                padding: 16px;
                spacing: 8px;

                TouchArea {
                    horizontal-stretch: 1;
                    clicked => { root.dismiss() }
                    Rectangle {
                        height: 40px;
                        background: parent.has-hover ? #2a2a2a : transparent;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #3a3a3a;
                        Text {
                            text: "Cancel";
                            color: #ccc;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                TouchArea {
                    horizontal-stretch: 1;
                    clicked => { root.save(root.name-text, root.url-text, root.remote-url-text, root.token-text) }
                    Rectangle {
                        height: 40px;
                        background: parent.has-hover ? #5599ff : #4a8cff;
                        border-radius: 6px;
                        Text {
                            text: "Save";
                            color: white;
                            font-size: 14px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component HostPicker inherits Rectangle {
    in property <[Host]> hosts;
    in property <int> selected-host;
    in property <length> safe-top;
    in property <length> safe-bottom;
    callback pick(int);
    callback edit(int);
    callback remove(int);
    callback add();
    callback dismiss();

    background: #000000aa;

    TouchArea {
        clicked => { root.dismiss() }
    }

    Rectangle {
        width: min(parent.width * 88%, 420px);
        height: min(parent.height * 0.7, 80px + hosts.length * 64px);
        background: #1c1c1c;
        border-radius: 14px;
        border-width: 1px;
        border-color: #2a2a2a;
        y: root.safe-top + 24px;

        VerticalLayout {
            padding: 0;
            spacing: 0;

            Rectangle {
                height: 48px;
                background: #232323;
                border-top-left-radius: 14px;
                border-top-right-radius: 14px;
                Text {
                    text: "Workstations";
                    color: #e0e0e0;
                    font-size: 16px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Flickable {
                VerticalLayout {
                    for h[i] in root.hosts : HostRow {
                        host: h;
                        selected: i == root.selected-host;
                        tapped => { root.pick(i) }
                        edited => { root.edit(i) }
                        removed => { root.remove(i) }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: #2a2a2a;
            }
            TouchArea {
                height: 48px;
                clicked => { root.add() }
                Rectangle {
                    background: parent.has-hover ? #2a2a2a : transparent;
                    border-bottom-left-radius: 14px;
                    border-bottom-right-radius: 14px;
                    Text {
                        text: "+ Add workstation";
                        color: #4a8cff;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

component KeyButton inherits Rectangle {
    in property <string> label;
    in property <string> icon-commands;  // SVG path data, optional
    in property <bool> active;           // highlight when a sticky modifier is on
    callback tapped();
    horizontal-stretch: 1;
    height: 36px;
    background: root.active ? #4a8cff : (ta.has-hover ? #1f3f6c : #16365d);
    border-radius: 4px;
    ta := TouchArea {
        clicked => { root.tapped() }
        if root.icon-commands == "" : Text {
            text: root.label;
            color: #e0eaff;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        if root.icon-commands != "" : Path {
            width: 20px;
            height: 20px;
            x: parent.width / 2 - 10px;
            y: parent.height / 2 - 10px;
            viewbox-width: 24;
            viewbox-height: 24;
            fill: #e0eaff;
            commands: root.icon-commands;
        }
    }
}

component KeyboardHeader inherits Rectangle {
    // Direct-send keys (ESC, arrows, function keys, TAB) emit byte
    // sequences over `send-bytes`; printable shortcuts (/, |, -) emit
    // `type-text` so the host integrates them into the input field
    // rather than dispatching to the terminal. KBD toggles the IME via
    // its own callback because that's a UI concern, not an input one.
    callback send-bytes(string);
    callback type-text(string);
    callback toggle-kbd();
    // FN flips the two-row layout to F1–F12, mirroring the Termux
    // pattern the user requested.
    in-out property <bool> fn-mode: false;
    // Sticky CTRL/ALT for future modifier work — visible state only,
    // dispatch isn't combined with the on-screen keyboard yet.
    in-out property <bool> ctrl-sticky: false;
    in-out property <bool> alt-sticky: false;

    height: 84px;
    background: #122b48;
    VerticalLayout {
        padding: 4px;
        spacing: 4px;

        // ── normal mode ─────────────────────────────────────────────
        if !root.fn-mode : HorizontalLayout {
            spacing: 4px;
            KeyButton { label: "ESC";     tapped => { root.send-bytes("\u{001b}") } }
            KeyButton { label: "/";       tapped => { root.type-text("/") } }
            KeyButton { label: "|";       tapped => { root.type-text("|") } }
            KeyButton { label: "-";       tapped => { root.type-text("-") } }
            KeyButton { label: "HOME";    tapped => { root.send-bytes("\u{001b}[H") } }
            KeyButton {
                icon-commands: "M 12 4 L 6 10 L 7.41 11.41 L 11 7.83 L 11 20 L 13 20 L 13 7.83 L 16.59 11.41 L 18 10 Z";
                tapped => { root.send-bytes("\u{001b}[A") }
            }
            KeyButton { label: "END";     tapped => { root.send-bytes("\u{001b}[F") } }
            KeyButton { label: "PGPRÉC";  tapped => { root.send-bytes("\u{001b}[5~") } }
            KeyButton { label: "FN";      active: root.fn-mode; tapped => { root.fn-mode = true; } }
        }
        if !root.fn-mode : HorizontalLayout {
            spacing: 4px;
            KeyButton { label: "TAB";     tapped => { root.send-bytes("\u{0009}") } }
            KeyButton { label: "CTRL";    active: root.ctrl-sticky; tapped => { root.ctrl-sticky = !root.ctrl-sticky; } }
            KeyButton { label: "ALT";     active: root.alt-sticky;  tapped => { root.alt-sticky  = !root.alt-sticky;  } }
            KeyButton {
                icon-commands: "M 20 11 L 7.83 11 L 13.42 5.41 L 12 4 L 4 12 L 12 20 L 13.41 18.59 L 7.83 13 L 20 13 Z";
                tapped => { root.send-bytes("\u{001b}[D") }
            }
            KeyButton {
                icon-commands: "M 12 20 L 18 14 L 16.59 12.59 L 13 16.17 L 13 4 L 11 4 L 11 16.17 L 7.41 12.59 L 6 14 Z";
                tapped => { root.send-bytes("\u{001b}[B") }
            }
            KeyButton {
                icon-commands: "M 4 13 L 16.17 13 L 10.58 18.59 L 12 20 L 20 12 L 12 4 L 10.59 5.41 L 16.17 11 L 4 11 Z";
                tapped => { root.send-bytes("\u{001b}[C") }
            }
            KeyButton { label: "PGSUIV";  tapped => { root.send-bytes("\u{001b}[6~") } }
            KeyButton {
                icon-commands: "M 20 5 L 4 5 C 2.89 5 2 5.89 2 7 L 2 17 C 2 18.11 2.89 19 4 19 L 20 19 C 21.11 19 22 18.11 22 17 L 22 7 C 22 5.89 21.11 5 20 5 Z M 11 8 L 13 8 L 13 10 L 11 10 Z M 11 11 L 13 11 L 13 13 L 11 13 Z M 8 8 L 10 8 L 10 10 L 8 10 Z M 8 11 L 10 11 L 10 13 L 8 13 Z M 7 13 L 5 13 L 5 11 L 7 11 Z M 7 10 L 5 10 L 5 8 L 7 8 Z M 16 17 L 8 17 L 8 15 L 16 15 Z M 16 13 L 14 13 L 14 11 L 16 11 Z M 16 10 L 14 10 L 14 8 L 16 8 Z M 19 13 L 17 13 L 17 11 L 19 11 Z M 19 10 L 17 10 L 17 8 L 19 8 Z";
                tapped => { root.toggle-kbd() }
            }
        }

        // ── FN mode (F1–F12) ─────────────────────────────────────────
        // Sequences match the standard xterm/VT220 mapping used by
        // most TUIs: F1–F4 as SS3 P/Q/R/S and F5+ as CSI ~ codes.
        if root.fn-mode : HorizontalLayout {
            spacing: 4px;
            KeyButton { label: "F1"; tapped => { root.send-bytes("\u{001b}OP");   root.fn-mode = false; } }
            KeyButton { label: "F2"; tapped => { root.send-bytes("\u{001b}OQ");   root.fn-mode = false; } }
            KeyButton { label: "F3"; tapped => { root.send-bytes("\u{001b}OR");   root.fn-mode = false; } }
            KeyButton { label: "F4"; tapped => { root.send-bytes("\u{001b}OS");   root.fn-mode = false; } }
            KeyButton { label: "F5"; tapped => { root.send-bytes("\u{001b}[15~"); root.fn-mode = false; } }
            KeyButton { label: "F6"; tapped => { root.send-bytes("\u{001b}[17~"); root.fn-mode = false; } }
            KeyButton { label: "F7"; tapped => { root.send-bytes("\u{001b}[18~"); root.fn-mode = false; } }
        }
        if root.fn-mode : HorizontalLayout {
            spacing: 4px;
            KeyButton { label: "F8";  tapped => { root.send-bytes("\u{001b}[19~"); root.fn-mode = false; } }
            KeyButton { label: "F9";  tapped => { root.send-bytes("\u{001b}[20~"); root.fn-mode = false; } }
            KeyButton { label: "F10"; tapped => { root.send-bytes("\u{001b}[21~"); root.fn-mode = false; } }
            KeyButton { label: "F11"; tapped => { root.send-bytes("\u{001b}[23~"); root.fn-mode = false; } }
            KeyButton { label: "F12"; tapped => { root.send-bytes("\u{001b}[24~"); root.fn-mode = false; } }
            // Explicit back-out — without this the only way to leave
            // FN-mode is to commit an F-key press.
            KeyButton {
                icon-commands: "M 20 11 L 7.83 11 L 13.42 5.41 L 12 4 L 4 12 L 12 20 L 13.41 18.59 L 7.83 13 L 20 13 Z";
                tapped => { root.fn-mode = false; }
            }
        }
    }
}

component TerminalView inherits Rectangle {
    in property <TabRow> tab;
    in property <[ColorLine]> output-lines;
    in property <length> safe-top;
    in property <length> safe-bottom;
    in property <length> safe-left;
    in property <length> safe-right;
    in property <length> ime-height;
    in-out property <length> font-size: 13px;
    // Transient buffer fed by the hidden TextInput. Always empty
    // outside of an in-flight `edited` flush.
    in-out property <string> capture-buffer: "";
    callback back();
    /// Raw byte sequence to feed straight to the terminal — used by
    /// shortcut keys (ESC, arrows, function keys, …).
    callback key-tapped(string);
    /// User-typed characters that should be transformed by sticky
    /// modifiers before reaching the host. The bool args are the
    /// CTRL/ALT sticky states at flush time; they're cleared by the
    /// caller after this fires.
    callback typed(string, bool, bool);

    // Auto-scroll to bottom whenever new output arrives. Setting
    // viewport-y to a negative value scrolls the content upwards — the
    // bottom of output-content lines up with the bottom of the flickable.
    // A subsequent user scroll-up briefly moves away from the bottom; the
    // next 2 s poll re-anchors.
    changed output-lines => {
        flick.viewport-y = min(0px, flick.height - flick.viewport-height);
    }
    // Same re-anchor whenever the IME shows or hides: the layout shrinks
    // by `ime-height`, so the previous viewport-y leaves the bottom rows
    // cut off behind the keyboard.
    changed ime-height => {
        flick.viewport-y = min(0px, flick.height - flick.viewport-height);
    }

    background: #0e0e0e;

    VerticalLayout {
        spacing: 0;
        padding-top: root.safe-top;
        // Shrink the layout by the IME height when the keyboard is up so
        // the input bar (last child of this layout) floats above it
        // instead of being painted underneath.
        padding-bottom: max(root.safe-bottom, root.ime-height);
        padding-left: root.safe-left;
        padding-right: root.safe-right;

        // Top bar
        Rectangle {
            height: 52px;
            background: #181818;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 12px;
                spacing: 8px;
                alignment: stretch;
                TouchArea {
                    width: 44px;
                    clicked => { root.back() }
                    Rectangle {
                        background: parent.has-hover ? #2a2a2a : transparent;
                        border-radius: 6px;
                        Path {
                            width: 24px;
                            height: 24px;
                            x: parent.width / 2 - 12px;
                            y: parent.height / 2 - 12px;
                            viewbox-width: 24;
                            viewbox-height: 24;
                            fill: #e0e0e0;
                            commands: "M 20 11 L 7.83 11 L 13.42 5.41 L 12 4 L 4 12 L 12 20 L 13.41 18.59 L 7.83 13 L 20 13 Z";
                        }
                    }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 2px;
                    Text {
                        text: tab.name;
                        color: #f0f0f0;
                        font-size: 16px;
                        font-weight: 600;
                        overflow: elide;
                    }
                    Text {
                        text: tab.cwd;
                        color: #888;
                        font-size: 11px;
                        overflow: elide;
                    }
                }
                Text {
                    text: tab.cpu;
                    color: #aaa;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                TouchArea {
                    width: 34px;
                    clicked => {
                        if (root.font-size > 9px) { root.font-size -= 1px; }
                    }
                    Rectangle {
                        background: parent.has-hover ? #2a2a2a : transparent;
                        border-radius: 6px;
                        Text {
                            text: "A−";
                            color: #aaa;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                TouchArea {
                    width: 34px;
                    clicked => {
                        if (root.font-size < 26px) { root.font-size += 1px; }
                    }
                    Rectangle {
                        background: parent.has-hover ? #2a2a2a : transparent;
                        border-radius: 6px;
                        Text {
                            text: "A+";
                            color: #e0e0e0;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #2a2a2a;
        }

        flick := Flickable {
            vertical-stretch: 1;
            interactive: true;
            viewport-width: output-content.preferred-width;
            viewport-height: output-content.preferred-height;
            output-content := VerticalLayout {
                padding: 10px;
                spacing: 0;
                if root.output-lines.length == 0 : Text {
                    text: "Waiting for output…";
                    color: #666;
                    font-family: "FreeMono";
                    font-size: root.font-size;
                }
                // One HorizontalLayout per terminal row, one Text per
                // contiguous same-colour run. FreeMono is monospace, so
                // spans line up without explicit cell widths.
                for line[i] in root.output-lines : HorizontalLayout {
                    spacing: 0px;
                    alignment: start;
                    for span[j] in line.spans : Text {
                        text: span.text;
                        color: span.color;
                        font-family: "FreeMono";
                        font-size: root.font-size;
                        font-weight: span.bold ? 700 : 400;
                        wrap: no-wrap;
                    }
                }
            }
        }

        // Sink FocusScope used to dismiss the IME — focusing a non-text
        // item makes Slint drop TextInputInterface.text-input-focused
        // which the Android backend wires to InputMethodManager.hide(...).
        hide-focus := FocusScope { width: 0; height: 0; }

        // Hidden capture buffer — kept invisible so the user types
        // straight "into the terminal". Each `edited` flush forwards
        // the new characters (with sticky CTRL/ALT applied on the Rust
        // side) and clears the buffer so it never grows. The IME only
        // shows while this widget has focus, which is what KBD toggles.
        Rectangle {
            height: 0px;
            width: 0px;
            clip: true;
            input-field := TextInput {
                text <=> root.capture-buffer;
                color: transparent;
                font-size: 1px;
                single-line: true;
                edited => {
                    if (root.capture-buffer != "") {
                        root.typed(
                            root.capture-buffer,
                            kh.ctrl-sticky,
                            kh.alt-sticky,
                        );
                        root.capture-buffer = "";
                        kh.ctrl-sticky = false;
                        kh.alt-sticky = false;
                    }
                }
                accepted => {
                    // Standard Enter is sent as part of the regular text
                    // stream, but some IMEs swallow the trailing newline —
                    // fire one explicitly here as a safety net.
                    root.key-tapped("\n");
                }
            }
        }

        kh := KeyboardHeader {
            // Bytes route straight to the host's tab-input callback.
            send-bytes(b) => { root.key-tapped(b); }
            // `/`, `|`, `-` no longer have an input field to land in;
            // dispatch them directly to the terminal too.
            type-text(t) => { root.key-tapped(t); }
            toggle-kbd => {
                if (root.ime-height > 0px) {
                    hide-focus.focus();
                } else {
                    input-field.focus();
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "Tab Atelier Remote";
    background: #121212;

    in-out property <[TabRow]> tabs: [];

    in-out property <[Host]> hosts: [];

    in-out property <int> active-host: 0;
    in-out property <int> open-tab: -1;
    in-out property <bool> picker-open: false;
    in-out property <bool> editor-open: false;
    /// -1 means "add new host"; >= 0 means "edit host at that index".
    in-out property <int> editor-edit-index: -1;
    in-out property <string> editor-name: "";
    in-out property <string> editor-url: "";
    in-out property <string> editor-remote-url: "";
    in-out property <string> editor-token: "";
    in-out property <string> editor-error: "";
    in-out property <[ColorLine]> open-tab-output-lines: [];
    /// -1 = no close confirmation dialog open; >= 0 = index of the tab the
    /// user just hit the X on.
    in-out property <int> close-confirm-idx: -1;
    in-out property <string> close-confirm-name: "";
    /// -1 = no action sheet; >= 0 = index of the tab whose "..." was
    /// tapped. Used to surface Rename/Close from a bottom sheet so
    /// they're discoverable without crowding the row.
    in-out property <int> actions-idx: -1;
    /// System battery level (0–100). -1 means "unknown / not queried
    /// yet"; pushed from the Rust JNI poller every 30 s. Drives the
    /// red warning bar at the top of the window: solid at <20 %,
    /// blinking at <10 %.
    in-out property <int> battery-level: -1;
    in-out property <bool> _battery_blink: false;
    /// -1 = no rename dialog open; >= 0 = index of the tab being renamed.
    in-out property <int> rename-idx: -1;
    in-out property <string> rename-text: "";
    /// Transient toast text + visibility. Rust sets `toast-text` on
    /// connect/disconnect events; the timer below auto-dismisses 3 s later.
    in-out property <string> toast-text: "";
    in-out property <bool> toast-visible: false;

    callback request-activate(int);
    callback request-send-input(int, string);
    /// Free-typed characters that should be transformed by sticky
    /// CTRL/ALT before being sent to the active tab. Implemented on
    /// the Rust side so the ASCII→Ctrl-byte mapping doesn't have to
    /// live in Slint.
    callback request-typed-text(int, string, bool, bool);
    callback request-add-host(string, string, string, string);
    callback request-update-host(int, string, string, string, string);
    callback request-close-tab(int);
    callback request-new-tab();
    callback request-rename-tab(int, string);
    callback request-scan-qr();
    callback request-set-active-host(int);
    callback request-remove-host(int);
    callback open-tab-changed(int);

    changed open-tab => { root.open-tab-changed(root.open-tab) }

    // Wrap every visible child in a FocusScope so the Android Back key —
    // dispatched by Slint as Key.Back — bubbles from any focused widget
    // (TextInputs in dialogs, etc.) up to this handler. Used to be a
    // sibling of the main layout, which meant focus on a TextInput
    // swallowed Back and the OS closed the activity.
    fs := FocusScope {
        init => { fs.focus() }
        key-pressed(event) => {
            if event.text == Key.Escape || event.text == Key.Back {
                if root.actions-idx >= 0 {
                    root.actions-idx = -1;
                    return accept;
                }
                if root.rename-idx >= 0 {
                    root.rename-idx = -1;
                    return accept;
                }
                if root.close-confirm-idx >= 0 {
                    root.close-confirm-idx = -1;
                    return accept;
                }
                if root.editor-open {
                    root.editor-open = false;
                    return accept;
                }
                if root.picker-open {
                    root.picker-open = false;
                    return accept;
                }
                if root.open-tab >= 0 {
                    root.open-tab = -1;
                    return accept;
                }
            }
            return reject;
        }

    VerticalLayout {
        spacing: 0;
        padding-top: root.safe-area-insets.top;
        padding-bottom: root.safe-area-insets.bottom;
        padding-left: root.safe-area-insets.left;
        padding-right: root.safe-area-insets.right;

        HeaderBar {
            host-name: root.hosts.length > 0 ? root.hosts[root.active-host].name : "No host";
            reachability: root.hosts.length > 0 ? root.hosts[root.active-host].reachability : "offline";
            detail: root.hosts.length > 0 ? root.hosts[root.active-host].detail : "tap + to add a workstation";
            multi-host: root.hosts.length > 1;
            host-tap => { root.picker-open = true; }
            add-host-tap => {
                root.editor-edit-index = -1;
                root.editor-name = "";
                root.editor-url = "";
                root.editor-remote-url = "";
                root.editor-token = "";
                root.editor-error = "";
                root.editor-open = true;
            }
        }

        Rectangle {
            height: 1px;
            background: #2a2a2a;
        }

        if root.hosts.length == 0 : Rectangle {
            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                alignment: center;
                Text {
                    text: "Welcome to Tab Atelier Remote";
                    color: #e0e0e0;
                    font-size: 18px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }
                Text {
                    text: "On the desktop, open Tab Atelier's QR dialog and either scan the QR with your phone camera (which dispatches via the taremote:// deep link) or copy the URL and paste it here.";
                    color: #aaa;
                    font-size: 13px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    alignment: center;
                    TouchArea {
                        width: 220px;
                        clicked => { root.request-scan-qr() }
                        Rectangle {
                            height: 44px;
                            background: parent.has-hover ? #5599ff : #4a8cff;
                            border-radius: 8px;
                            HorizontalLayout {
                                alignment: center;
                                spacing: 8px;
                                // Material content_paste icon
                                Path {
                                    width: 22px;
                                    height: 22px;
                                    y: parent.height / 2 - 11px;
                                    viewbox-width: 24;
                                    viewbox-height: 24;
                                    fill: white;
                                    commands: "M 19 2 L 14.82 2 C 14.4 0.84 13.3 0 12 0 C 10.7 0 9.6 0.84 9.18 2 L 5 2 C 3.9 2 3 2.9 3 4 L 3 20 C 3 21.1 3.9 22 5 22 L 19 22 C 20.1 22 21 21.1 21 20 L 21 4 C 21 2.9 20.1 2 19 2 Z M 12 2 C 12.55 2 13 2.45 13 3 C 13 3.55 12.55 4 12 4 C 11.45 4 11 3.55 11 3 C 11 2.45 11.45 2 12 2 Z M 19 20 L 5 20 L 5 4 L 7 4 L 7 7 L 17 7 L 17 4 L 19 4 L 19 20 Z";
                                }
                                Text {
                                    text: "Paste URL";
                                    color: white;
                                    font-size: 15px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }

        if root.hosts.length > 0 : Flickable {
            VerticalLayout {
                padding: 12px;
                spacing: 8px;
                for tab[i] in root.tabs : TabCard {
                    tab: tab;
                    // Tap = open the tab's output on the phone only.
                    // Switching the *desktop's* active tab is a separate
                    // explicit action (long-press / menu) so glancing
                    // through tabs on the phone doesn't yank the user's
                    // focus around on the workstation.
                    tapped => { root.open-tab = i; }
                    actions-requested => { root.actions-idx = i; }
                }

                // New-tab affordance — rendered as a dashed-border card to
                // visually distinguish it from real tab rows.
                if root.tabs.length > 0 : Rectangle {
                    height: 56px;
                    background: new_ta.has-hover ? #1f2a3a : #161e2a;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #2a4060;
                    new_ta := TouchArea {
                        clicked => { root.request-new-tab() }
                        HorizontalLayout {
                            alignment: center;
                            spacing: 8px;
                            Rectangle {
                                width: 22px;
                                height: 22px;
                                y: parent.height / 2 - 11px;
                                Path {
                                    width: 22px;
                                    height: 22px;
                                    viewbox-width: 24;
                                    viewbox-height: 24;
                                    fill: #4a8cff;
                                    commands: "M 19 13 L 13 13 L 13 19 L 11 19 L 11 13 L 5 13 L 5 11 L 11 11 L 11 5 L 13 5 L 13 11 L 19 11 Z";
                                }
                            }
                            Text {
                                text: "New tab";
                                color: #4a8cff;
                                font-size: 14px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.open-tab >= 0 : TerminalView {
        width: 100%;
        height: 100%;
        tab: root.tabs[root.open-tab];
        output-lines: root.open-tab-output-lines;
        safe-top: root.safe-area-insets.top;
        safe-bottom: root.safe-area-insets.bottom;
        safe-left: root.safe-area-insets.left;
        safe-right: root.safe-area-insets.right;
        ime-height: root.virtual-keyboard-size.height;
        back => { root.open-tab = -1; }
        // Shortcut keys produce ready-to-send byte sequences.
        key-tapped(bytes) => { root.request-send-input(root.open-tab, bytes); }
        // Free-typed characters go through `request-typed-text` so the
        // host-side handler can fold sticky CTRL / ALT into them
        // (Ctrl-A → 0x01, Alt-X → "\x1bx", etc.).
        typed(text, ctrl, alt) => {
            root.request-typed-text(root.open-tab, text, ctrl, alt);
        }
    }

    if root.picker-open : HostPicker {
        width: 100%;
        height: 100%;
        hosts: root.hosts;
        selected-host: root.active-host;
        safe-top: root.safe-area-insets.top;
        safe-bottom: root.safe-area-insets.bottom;
        pick(i) => {
            root.active-host = i;
            root.picker-open = false;
            root.request-set-active-host(i);
        }
        edit(i) => {
            root.editor-edit-index = i;
            root.editor-name = root.hosts[i].name;
            root.editor-url = root.hosts[i].url;
            root.editor-remote-url = root.hosts[i].remote-url;
            root.editor-token = root.hosts[i].token;
            root.editor-error = "";
            root.picker-open = false;
            root.editor-open = true;
        }
        remove(i) => {
            root.request-remove-host(i);
            if (root.hosts.length <= 1) {
                root.picker-open = false;
            }
        }
        add => {
            root.picker-open = false;
            root.editor-edit-index = -1;
            root.editor-name = "";
            root.editor-url = "";
            root.editor-remote-url = "";
            root.editor-token = "";
            root.editor-error = "";
            root.editor-open = true;
        }
        dismiss => { root.picker-open = false; }
    }

    if root.editor-open : HostEditor {
        width: 100%;
        height: 100%;
        safe-top: root.safe-area-insets.top;
        ime-height: root.virtual-keyboard-size.height;
        editing: root.editor-edit-index >= 0;
        name-text <=> root.editor-name;
        url-text <=> root.editor-url;
        remote-url-text <=> root.editor-remote-url;
        token-text <=> root.editor-token;
        error <=> root.editor-error;
        save(n, u, r, t) => {
            if (u == "" || t == "") {
                root.editor-error = "URL and Token are required.";
            } else {
                root.editor-error = "";
                root.editor-open = false;
                if (root.editor-edit-index >= 0) {
                    root.request-update-host(root.editor-edit-index, n, u, r, t);
                } else {
                    root.request-add-host(n, u, r, t);
                }
            }
        }
        dismiss => { root.editor-open = false; }
    }

    // Bottom action sheet for a single tab — invoked from the TabCard's
    // "..." button. Pulls Rename / Close out of the row so the inline
    // buttons stop competing with the tab name and preview text.
    if root.actions-idx >= 0 : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000aa;
        TouchArea { clicked => { root.actions-idx = -1 } }

        Rectangle {
            width: min(parent.width * 92%, 480px);
            height: 220px;
            y: parent.height - self.height - 16px - root.safe-area-insets.bottom;
            background: #1c1c1c;
            border-radius: 14px;
            border-width: 1px;
            border-color: #2a2a2a;

            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: 48px;
                    background: #232323;
                    border-top-left-radius: 14px;
                    border-top-right-radius: 14px;
                    Text {
                        text: root.actions-idx >= 0 && root.actions-idx < root.tabs.length
                              ? root.tabs[root.actions-idx].name
                              : "";
                        color: #e0e0e0;
                        font-size: 15px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                TouchArea {
                    height: 56px;
                    clicked => {
                        if (root.actions-idx >= 0) {
                            root.rename-idx = root.actions-idx;
                            root.rename-text = root.tabs[root.actions-idx].name;
                            root.actions-idx = -1;
                        }
                    }
                    Rectangle {
                        background: parent.has-hover ? #2a2a2a : transparent;
                        HorizontalLayout {
                            padding-left: 16px;
                            spacing: 12px;
                            alignment: start;
                            Rectangle {
                                width: 24px;
                                height: 24px;
                                y: parent.height / 2 - 12px;
                                Path {
                                    width: 22px;
                                    height: 22px;
                                    viewbox-width: 24;
                                    viewbox-height: 24;
                                    fill: #aaaaaa;
                                    commands: "M 3 17.25 L 3 21 L 6.75 21 L 17.81 9.94 L 14.06 6.19 L 3 17.25 Z M 20.71 7.04 C 21.1 6.65 21.1 6.02 20.71 5.63 L 18.37 3.29 C 17.98 2.9 17.35 2.9 16.96 3.29 L 15.13 5.12 L 18.88 8.87 L 20.71 7.04 Z";
                                }
                            }
                            Text {
                                text: "Rename tab";
                                color: #e0e0e0;
                                font-size: 15px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: #2a2a2a; }

                TouchArea {
                    height: 56px;
                    clicked => {
                        if (root.actions-idx >= 0) {
                            root.close-confirm-idx = root.actions-idx;
                            root.close-confirm-name = root.tabs[root.actions-idx].name;
                            root.actions-idx = -1;
                        }
                    }
                    Rectangle {
                        background: parent.has-hover ? #3a1f1f : transparent;
                        HorizontalLayout {
                            padding-left: 16px;
                            spacing: 12px;
                            alignment: start;
                            Rectangle {
                                width: 24px;
                                height: 24px;
                                y: parent.height / 2 - 12px;
                                Path {
                                    width: 22px;
                                    height: 22px;
                                    viewbox-width: 24;
                                    viewbox-height: 24;
                                    fill: #ef5350;
                                    commands: "M 19 6.41 L 17.59 5 L 12 10.59 L 6.41 5 L 5 6.41 L 10.59 12 L 5 17.59 L 6.41 19 L 12 13.41 L 17.59 19 L 19 17.59 L 13.41 12 Z";
                                }
                            }
                            Text {
                                text: "Close tab";
                                color: #ef5350;
                                font-size: 15px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: #2a2a2a; }

                TouchArea {
                    height: 48px;
                    clicked => { root.actions-idx = -1 }
                    Rectangle {
                        background: parent.has-hover ? #2a2a2a : transparent;
                        border-bottom-left-radius: 14px;
                        border-bottom-right-radius: 14px;
                        Text {
                            text: "Cancel";
                            color: #ccc;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    if root.rename-idx >= 0 : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000aa;
        TouchArea { clicked => { root.rename-idx = -1 } }

        Rectangle {
            width: min(parent.width * 88%, 420px);
            height: 220px;
            // Same IME-aware positioning as the host editor: float up
            // when the keyboard is showing, otherwise anchor at top.
            y: root.virtual-keyboard-size.height > 0px
                ? max(root.safe-area-insets.top + 8px, parent.height - root.virtual-keyboard-size.height - self.height - 8px)
                : root.safe-area-insets.top + 24px;
            background: #1c1c1c;
            border-radius: 14px;
            border-width: 1px;
            border-color: #2a2a2a;

            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: 48px;
                    background: #232323;
                    border-top-left-radius: 14px;
                    border-top-right-radius: 14px;
                    Text {
                        text: "Rename tab";
                        color: #e0e0e0;
                        font-size: 16px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    padding: 16px;
                    spacing: 8px;
                    Text { text: "New name"; color: #888; font-size: 11px; }
                    Rectangle {
                        height: 40px;
                        background: #232323;
                        border-radius: 6px;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            rename-input := TextInput {
                                text <=> root.rename-text;
                                color: #e0e0e0;
                                font-size: 14px;
                                single-line: true;
                                vertical-alignment: center;
                                accepted => {
                                    if (root.rename-text != "") {
                                        root.request-rename-tab(root.rename-idx, root.rename-text);
                                    }
                                    root.rename-idx = -1;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => { root.rename-idx = -1 }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #2a2a2a : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #3a3a3a;
                            Text {
                                text: "Cancel";
                                color: #ccc;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => {
                            if (root.rename-text != "") {
                                root.request-rename-tab(root.rename-idx, root.rename-text);
                            }
                            root.rename-idx = -1;
                        }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #5599ff : #4a8cff;
                            border-radius: 6px;
                            Text {
                                text: "Rename";
                                color: white;
                                font-size: 14px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.close-confirm-idx >= 0 : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000aa;
        TouchArea { clicked => { root.close-confirm-idx = -1 } }

        Rectangle {
            width: min(parent.width * 88%, 380px);
            height: 200px;
            y: parent.height / 2 - 100px;
            background: #1c1c1c;
            border-radius: 14px;
            border-width: 1px;
            border-color: #2a2a2a;

            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: 48px;
                    background: #232323;
                    border-top-left-radius: 14px;
                    border-top-right-radius: 14px;
                    Text {
                        text: "Close tab?";
                        color: #e0e0e0;
                        font-size: 16px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    padding: 18px;
                    spacing: 10px;
                    alignment: center;
                    Text {
                        text: "Send DELETE /tabs/… for";
                        color: #aaa;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "\"" + root.close-confirm-name + "\"";
                        color: #f0f0f0;
                        font-size: 15px;
                        font-weight: 600;
                        font-family: "FreeMono";
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                }

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => { root.close-confirm-idx = -1 }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #2a2a2a : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #3a3a3a;
                            Text {
                                text: "Cancel";
                                color: #ccc;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => {
                            root.request-close-tab(root.close-confirm-idx);
                            root.close-confirm-idx = -1;
                        }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #d04545 : #ef5350;
                            border-radius: 6px;
                            Text {
                                text: "Close";
                                color: white;
                                font-size: 14px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
    }

    // Transient connection-state toast — anchored top-center, fades itself
    // after 3 s. Rust sets toast-text on lan/remote ↔ offline transitions.
    Timer {
        interval: 3s;
        running: root.toast-visible;
        triggered => { root.toast-visible = false; }
    }

    // Battery warning banner: visible whenever level is known and ≤20 %.
    // Blink driver toggles a bool at 1 Hz when we drop to ≤10 % so the
    // bar pulses instead of fading silently into the chrome.
    Timer {
        interval: 600ms;
        running: root.battery-level >= 0 && root.battery-level <= 10;
        triggered => { root._battery_blink = !root._battery_blink; }
    }
    if root.battery-level >= 0 && root.battery-level <= 20 : Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 4px;
        background: root.battery-level <= 10 && root._battery_blink
            ? transparent
            : #ef5350;
    }
    if root.toast-visible : Rectangle {
        width: 100%;
        y: root.safe-area-insets.top + 8px;
        height: 40px;
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: min(parent.width * 88%, 360px);
                height: 40px;
                background: #2a2a2a;
                border-radius: 8px;
                border-width: 1px;
                border-color: #4a4a4a;
                Text {
                    text: root.toast-text;
                    color: #e0e0e0;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
