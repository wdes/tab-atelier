struct TabRow {
    name: string,
    cwd: string,
    active: bool,
    cpu: string,
    preview: string,
    /// Set when the preview text has changed since the user last opened
    /// this tab — used to surface "this tab moved" without having to open it.
    has-new: bool,
}

struct Host {
    name: string,
    reachability: string,    // "lan" | "remote" | "offline"
    detail: string,          // shown next to the badge
    url: string,             // LAN URL
    remote-url: string,      // optional remote URL
    token: string,
}

component HeaderBar inherits Rectangle {
    in property <string> host-name;
    in property <string> reachability;
    in property <string> detail;
    in property <bool> multi-host;
    callback host-tap();
    callback add-host-tap();

    height: 64px;
    background: #181818;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 12px;
        alignment: stretch;

        TouchArea {
            enabled: root.multi-host;
            clicked => { root.host-tap() }
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: root.host-name;
                            color: #e0e0e0;
                            font-size: 18px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        if root.multi-host : Rectangle {
                            width: 18px;
                            height: 18px;
                            y: parent.height / 2 - 9px;
                            Path {
                                viewbox-width: 24;
                                viewbox-height: 24;
                                fill: #888;
                                commands: "M 7 10 L 12 15 L 17 10 Z";
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: root.reachability == "lan" ? #66bb6a
                                : root.reachability == "remote" ? #ffa726
                                : root.reachability == "connecting" ? #aaaaaa
                                : #ef5350;
                            y: parent.height / 2 - 4px;
                        }
                        Text {
                            text: (root.reachability == "lan" ? "LAN · "
                                : root.reachability == "remote" ? "Remote · "
                                : root.reachability == "connecting" ? "Connecting · "
                                : "Offline · ") + root.detail;
                            color: root.reachability == "lan" ? #66bb6a
                                : root.reachability == "remote" ? #ffa726
                                : root.reachability == "connecting" ? #aaaaaa
                                : #ef5350;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        Rectangle { horizontal-stretch: 1; }

        TouchArea {
            width: 44px;
            clicked => { root.add-host-tap() }
            Rectangle {
                background: parent.has-hover ? #2a2a2a : transparent;
                border-radius: 6px;
                Text {
                    text: "+";
                    color: #e0e0e0;
                    font-size: 26px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

component TabCard inherits Rectangle {
    in property <TabRow> tab;
    callback tapped();
    callback rename-requested();
    callback close-requested();

    height: 96px;
    background: ta.has-hover ? #232323 : #1e1e1e;
    border-radius: 8px;
    border-width: 1px;
    border-color: tab.active ? #4a8cff : #2a2a2a;

    HorizontalLayout {
        padding: 0;
        spacing: 0;

        ta := TouchArea {
            horizontal-stretch: 1;
            clicked => { root.tapped() }

            HorizontalLayout {
                padding: 12px;
                spacing: 12px;

                Rectangle {
                    width: 8px;
                    background: tab.active ? #4a8cff : #555;
                    border-radius: 4px;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 3px;

                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Text {
                            text: tab.name;
                            color: #f0f0f0;
                            font-size: 16px;
                            font-weight: 600;
                            overflow: elide;
                        }
                        if tab.has-new : Rectangle {
                            width: 8px;
                            height: 8px;
                            y: parent.height / 2 - 4px;
                            border-radius: 4px;
                            background: #66bb6a;
                        }
                    }
                    Text {
                        text: tab.cwd;
                        color: #888;
                        font-size: 12px;
                        overflow: elide;
                    }
                    Text {
                        text: tab.preview;
                        color: #6b8caf;
                        font-size: 11px;
                        font-family: "monospace";
                        overflow: elide;
                    }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    Text {
                        text: tab.cpu;
                        color: #aaa;
                        font-size: 12px;
                        horizontal-alignment: right;
                    }
                    Text {
                        text: tab.active ? "active" : "";
                        color: #4a8cff;
                        font-size: 11px;
                        horizontal-alignment: right;
                    }
                }
            }
        }

        TouchArea {
            width: 40px;
            clicked => { root.rename-requested() }
            Rectangle {
                background: parent.has-hover ? #2a2a2a : transparent;
                border-radius: 6px;
                // Material edit (pencil) icon, same shape as host row.
                Path {
                    width: 18px;
                    height: 18px;
                    x: parent.width / 2 - 9px;
                    y: parent.height / 2 - 9px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: #888;
                    commands: "M 3 17.25 L 3 21 L 6.75 21 L 17.81 9.94 L 14.06 6.19 L 3 17.25 Z M 20.71 7.04 C 21.1 6.65 21.1 6.02 20.71 5.63 L 18.37 3.29 C 17.98 2.9 17.35 2.9 16.96 3.29 L 15.13 5.12 L 18.88 8.87 L 20.71 7.04 Z";
                }
            }
        }

        TouchArea {
            width: 40px;
            clicked => { root.close-requested() }
            Rectangle {
                background: parent.has-hover ? #3a1f1f : transparent;
                border-radius: 6px;
                Path {
                    width: 18px;
                    height: 18px;
                    x: parent.width / 2 - 9px;
                    y: parent.height / 2 - 9px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: #888;
                    commands: "M 19 6.41 L 17.59 5 L 12 10.59 L 6.41 5 L 5 6.41 L 10.59 12 L 5 17.59 L 6.41 19 L 12 13.41 L 17.59 19 L 19 17.59 L 13.41 12 Z";
                }
            }
        }
    }
}

component HostRow inherits Rectangle {
    in property <Host> host;
    in property <bool> selected;
    callback tapped();
    callback edited();
    callback removed();

    height: 64px;
    background: ta.has-hover ? #2a2a2a : transparent;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 4px;
        spacing: 12px;

        ta := TouchArea {
            horizontal-stretch: 1;
            clicked => { root.tapped() }

            HorizontalLayout {
                spacing: 12px;

                Rectangle {
                    width: 10px;
                    background: host.reachability == "lan" ? #66bb6a
                        : host.reachability == "remote" ? #ffa726
                        : host.reachability == "connecting" ? #aaaaaa
                        : #ef5350;
                    border-radius: 5px;
                    y: parent.height / 2 - self.height / 2;
                    height: 10px;
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 2px;
                    Text {
                        text: host.name;
                        color: #f0f0f0;
                        font-size: 15px;
                        font-weight: 600;
                    }
                    Text {
                        text: host.detail;
                        color: #888;
                        font-size: 12px;
                    }
                }

                Rectangle {
                    width: 24px;
                    if root.selected : Path {
                        width: 24px;
                        height: 24px;
                        x: parent.width / 2 - 12px;
                        y: parent.height / 2 - 12px;
                        viewbox-width: 24;
                        viewbox-height: 24;
                        fill: #4a8cff;
                        commands: "M 9 16.17 L 4.83 12 L 3.41 13.41 L 9 19 L 21 7 L 19.59 5.59 Z";
                    }
                }
            }
        }

        TouchArea {
            width: 36px;
            clicked => { root.edited() }
            Rectangle {
                background: parent.has-hover ? #2a2a2a : transparent;
                border-radius: 6px;
                // Material `edit` (pencil)
                Path {
                    width: 20px;
                    height: 20px;
                    x: parent.width / 2 - 10px;
                    y: parent.height / 2 - 10px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: #aaaaaa;
                    commands: "M 3 17.25 L 3 21 L 6.75 21 L 17.81 9.94 L 14.06 6.19 L 3 17.25 Z M 20.71 7.04 C 21.1 6.65 21.1 6.02 20.71 5.63 L 18.37 3.29 C 17.98 2.9 17.35 2.9 16.96 3.29 L 15.13 5.12 L 18.88 8.87 L 20.71 7.04 Z";
                }
            }
        }

        TouchArea {
            width: 36px;
            clicked => { root.removed() }
            Rectangle {
                background: parent.has-hover ? #3a1f1f : transparent;
                border-radius: 6px;
                Path {
                    width: 20px;
                    height: 20px;
                    x: parent.width / 2 - 10px;
                    y: parent.height / 2 - 10px;
                    viewbox-width: 24;
                    viewbox-height: 24;
                    fill: #ef5350;
                    commands: "M 19 6.41 L 17.59 5 L 12 10.59 L 6.41 5 L 5 6.41 L 10.59 12 L 5 17.59 L 6.41 19 L 12 13.41 L 17.59 19 L 19 17.59 L 13.41 12 Z";
                }
            }
        }
    }
}

component HostEditor inherits Rectangle {
    in property <length> safe-top;
    in property <bool> editing;
    in-out property <string> name-text;
    in-out property <string> url-text;
    in-out property <string> remote-url-text;
    in-out property <string> token-text;
    callback save(string, string, string, string);
    callback dismiss();

    background: #000000aa;

    TouchArea {
        clicked => { root.dismiss() }
    }

    Rectangle {
        width: min(parent.width * 88%, 480px);
        height: 440px;
        background: #1c1c1c;
        border-radius: 14px;
        border-width: 1px;
        border-color: #2a2a2a;
        y: root.safe-top + 24px;

        VerticalLayout {
            padding: 0;
            spacing: 0;

            Rectangle {
                height: 48px;
                background: #232323;
                border-top-left-radius: 14px;
                border-top-right-radius: 14px;
                Text {
                    text: root.editing ? "Edit workstation" : "Add workstation";
                    color: #e0e0e0;
                    font-size: 16px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text { text: "Name"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.name-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }

                Text { text: "LAN URL (http://192.168.x.x:7890)"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.url-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }

                Text { text: "Remote URL (optional)"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.remote-url-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }

                Text { text: "Token"; color: #888; font-size: 11px; }
                Rectangle {
                    height: 40px;
                    background: #232323;
                    border-radius: 6px;
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        TextInput {
                            text <=> root.token-text;
                            color: #e0e0e0;
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            HorizontalLayout {
                padding: 16px;
                spacing: 8px;

                TouchArea {
                    horizontal-stretch: 1;
                    clicked => { root.dismiss() }
                    Rectangle {
                        height: 40px;
                        background: parent.has-hover ? #2a2a2a : transparent;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #3a3a3a;
                        Text {
                            text: "Cancel";
                            color: #ccc;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                TouchArea {
                    horizontal-stretch: 1;
                    clicked => { root.save(root.name-text, root.url-text, root.remote-url-text, root.token-text) }
                    Rectangle {
                        height: 40px;
                        background: parent.has-hover ? #5599ff : #4a8cff;
                        border-radius: 6px;
                        Text {
                            text: "Save";
                            color: white;
                            font-size: 14px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component HostPicker inherits Rectangle {
    in property <[Host]> hosts;
    in property <int> selected-host;
    in property <length> safe-top;
    in property <length> safe-bottom;
    callback pick(int);
    callback edit(int);
    callback remove(int);
    callback dismiss();

    background: #000000aa;

    TouchArea {
        clicked => { root.dismiss() }
    }

    Rectangle {
        width: min(parent.width * 88%, 420px);
        height: min(parent.height * 0.7, 80px + hosts.length * 64px);
        background: #1c1c1c;
        border-radius: 14px;
        border-width: 1px;
        border-color: #2a2a2a;
        y: root.safe-top + 24px;

        VerticalLayout {
            padding: 0;
            spacing: 0;

            Rectangle {
                height: 48px;
                background: #232323;
                border-top-left-radius: 14px;
                border-top-right-radius: 14px;
                Text {
                    text: "Workstations";
                    color: #e0e0e0;
                    font-size: 16px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Flickable {
                VerticalLayout {
                    for h[i] in root.hosts : HostRow {
                        host: h;
                        selected: i == root.selected-host;
                        tapped => { root.pick(i) }
                        edited => { root.edit(i) }
                        removed => { root.remove(i) }
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: #2a2a2a;
            }
            TouchArea {
                height: 48px;
                clicked => { root.dismiss() }
                Rectangle {
                    background: parent.has-hover ? #2a2a2a : transparent;
                    border-bottom-left-radius: 14px;
                    border-bottom-right-radius: 14px;
                    Text {
                        text: "+ Add workstation";
                        color: #4a8cff;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

component KeyButton inherits Rectangle {
    in property <string> label;
    in property <string> icon-commands;  // SVG path data, optional
    callback tapped();
    horizontal-stretch: 1;
    height: 36px;
    background: ta.has-hover ? #1f3f6c : #16365d;
    border-radius: 4px;
    ta := TouchArea {
        clicked => { root.tapped() }
        if root.icon-commands == "" : Text {
            text: root.label;
            color: #e0eaff;
            font-size: 12px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        if root.icon-commands != "" : Path {
            width: 20px;
            height: 20px;
            x: parent.width / 2 - 10px;
            y: parent.height / 2 - 10px;
            viewbox-width: 24;
            viewbox-height: 24;
            fill: #e0eaff;
            commands: root.icon-commands;
        }
    }
}

component KeyboardHeader inherits Rectangle {
    callback key-tapped(string);
    height: 84px;
    background: #122b48;
    VerticalLayout {
        padding: 4px;
        spacing: 4px;
        HorizontalLayout {
            spacing: 4px;
            KeyButton { label: "ESC";   tapped => { root.key-tapped("esc") } }
            KeyButton { label: "/";     tapped => { root.key-tapped("/") } }
            KeyButton { label: "|";     tapped => { root.key-tapped("|") } }
            KeyButton { label: "-";     tapped => { root.key-tapped("-") } }
            KeyButton { label: "HOME";  tapped => { root.key-tapped("home") } }
            KeyButton {
                icon-commands: "M 12 4 L 6 10 L 7.41 11.41 L 11 7.83 L 11 20 L 13 20 L 13 7.83 L 16.59 11.41 L 18 10 Z";
                tapped => { root.key-tapped("up") }
            }
            KeyButton { label: "END";   tapped => { root.key-tapped("end") } }
            KeyButton { label: "PGUP";  tapped => { root.key-tapped("pgup") } }
            KeyButton { label: "^C";    tapped => { root.key-tapped("ctrl-c") } }
        }
        HorizontalLayout {
            spacing: 4px;
            KeyButton { label: "TAB";   tapped => { root.key-tapped("tab") } }
            KeyButton { label: "^D";    tapped => { root.key-tapped("ctrl-d") } }
            KeyButton { label: "^Z";    tapped => { root.key-tapped("ctrl-z") } }
            KeyButton {
                icon-commands: "M 20 11 L 7.83 11 L 13.42 5.41 L 12 4 L 4 12 L 12 20 L 13.41 18.59 L 7.83 13 L 20 13 Z";
                tapped => { root.key-tapped("left") }
            }
            KeyButton {
                icon-commands: "M 12 20 L 18 14 L 16.59 12.59 L 13 16.17 L 13 4 L 11 4 L 11 16.17 L 7.41 12.59 L 6 14 Z";
                tapped => { root.key-tapped("down") }
            }
            KeyButton {
                icon-commands: "M 4 13 L 16.17 13 L 10.58 18.59 L 12 20 L 20 12 L 12 4 L 10.59 5.41 L 16.17 11 L 4 11 Z";
                tapped => { root.key-tapped("right") }
            }
            KeyButton { label: "PGDN";  tapped => { root.key-tapped("pgdn") } }
            KeyButton {
                // keyboard icon
                icon-commands: "M 20 5 L 4 5 C 2.89 5 2 5.89 2 7 L 2 17 C 2 18.11 2.89 19 4 19 L 20 19 C 21.11 19 22 18.11 22 17 L 22 7 C 22 5.89 21.11 5 20 5 Z M 11 8 L 13 8 L 13 10 L 11 10 Z M 11 11 L 13 11 L 13 13 L 11 13 Z M 8 8 L 10 8 L 10 10 L 8 10 Z M 8 11 L 10 11 L 10 13 L 8 13 Z M 7 13 L 5 13 L 5 11 L 7 11 Z M 7 10 L 5 10 L 5 8 L 7 8 Z M 16 17 L 8 17 L 8 15 L 16 15 Z M 16 13 L 14 13 L 14 11 L 16 11 Z M 16 10 L 14 10 L 14 8 L 16 8 Z M 19 13 L 17 13 L 17 11 L 19 11 Z M 19 10 L 17 10 L 17 8 L 19 8 Z";
                tapped => { root.key-tapped("kbd") }
            }
        }
    }
}

component TerminalView inherits Rectangle {
    in property <TabRow> tab;
    in property <string> output-text;
    in property <length> safe-top;
    in property <length> safe-bottom;
    in property <length> safe-left;
    in property <length> safe-right;
    in-out property <string> input-text;
    callback back();
    callback send-input();
    callback key-tapped(string);

    // Auto-scroll to bottom whenever the output text grows. Setting
    // viewport-y to a negative value scrolls the content upwards — the
    // bottom of output-content lines up with the bottom of the flickable.
    // A subsequent user scroll-up briefly moves away from the bottom; the
    // next 2 s poll re-anchors.
    changed output-text => {
        flick.viewport-y = min(0px, flick.height - flick.viewport-height);
    }

    background: #0e0e0e;

    VerticalLayout {
        spacing: 0;
        padding-top: root.safe-top;
        padding-bottom: root.safe-bottom;
        padding-left: root.safe-left;
        padding-right: root.safe-right;

        // Top bar
        Rectangle {
            height: 52px;
            background: #181818;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 12px;
                spacing: 8px;
                alignment: stretch;
                TouchArea {
                    width: 44px;
                    clicked => { root.back() }
                    Rectangle {
                        background: parent.has-hover ? #2a2a2a : transparent;
                        border-radius: 6px;
                        Path {
                            width: 24px;
                            height: 24px;
                            x: parent.width / 2 - 12px;
                            y: parent.height / 2 - 12px;
                            viewbox-width: 24;
                            viewbox-height: 24;
                            fill: #e0e0e0;
                            commands: "M 20 11 L 7.83 11 L 13.42 5.41 L 12 4 L 4 12 L 12 20 L 13.41 18.59 L 7.83 13 L 20 13 Z";
                        }
                    }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 2px;
                    Text {
                        text: tab.name;
                        color: #f0f0f0;
                        font-size: 16px;
                        font-weight: 600;
                        overflow: elide;
                    }
                    Text {
                        text: tab.cwd;
                        color: #888;
                        font-size: 11px;
                        overflow: elide;
                    }
                }
                Text {
                    text: tab.cpu;
                    color: #aaa;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #2a2a2a;
        }

        flick := Flickable {
            vertical-stretch: 1;
            interactive: true;
            viewport-height: output-content.preferred-height;
            output-content := VerticalLayout {
                padding: 10px;
                spacing: 0;
                if root.output-text != "" : Text {
                    text: root.output-text;
                    color: #d0d0d0;
                    font-family: "monospace";
                    font-size: 13px;
                    wrap: no-wrap;
                }
                if root.output-text == "" : Text {
                    text: "Waiting for output…";
                    color: #666;
                    font-family: "monospace";
                    font-size: 13px;
                }
            }
        }

        KeyboardHeader {
            key-tapped(k) => { root.key-tapped(k) }
        }

        Rectangle {
            height: 1px;
            background: #2a2a2a;
        }

        // Input bar
        Rectangle {
            height: 56px;
            background: #181818;
            HorizontalLayout {
                padding: 8px;
                spacing: 8px;
                Rectangle {
                    horizontal-stretch: 1;
                    background: #232323;
                    border-radius: 8px;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        TextInput {
                            text <=> root.input-text;
                            color: #e0e0e0;
                            font-family: "monospace";
                            font-size: 14px;
                            single-line: true;
                            vertical-alignment: center;
                            accepted => { root.send-input(); }
                        }
                    }
                }
                TouchArea {
                    width: 48px;
                    clicked => { root.send-input() }
                    Rectangle {
                        background: parent.has-hover ? #5599ff : #4a8cff;
                        border-radius: 8px;
                        Path {
                            width: 22px;
                            height: 22px;
                            x: parent.width / 2 - 11px;
                            y: parent.height / 2 - 11px;
                            viewbox-width: 24;
                            viewbox-height: 24;
                            fill: white;
                            commands: "M 2.01 21 L 23 12 L 2.01 3 L 2 10 L 17 12 L 2 14 Z";
                        }
                    }
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "Tab Atelier Remote";
    background: #121212;

    in-out property <[TabRow]> tabs: [];

    in-out property <[Host]> hosts: [];

    in-out property <int> active-host: 0;
    in-out property <int> open-tab: -1;
    in-out property <bool> picker-open: false;
    in-out property <bool> editor-open: false;
    /// -1 means "add new host"; >= 0 means "edit host at that index".
    in-out property <int> editor-edit-index: -1;
    in-out property <string> input-text: "";
    in-out property <string> editor-name: "";
    in-out property <string> editor-url: "";
    in-out property <string> editor-remote-url: "";
    in-out property <string> editor-token: "";
    in-out property <string> open-tab-output: "";
    /// -1 = no close confirmation dialog open; >= 0 = index of the tab the
    /// user just hit the X on.
    in-out property <int> close-confirm-idx: -1;
    in-out property <string> close-confirm-name: "";
    /// -1 = no rename dialog open; >= 0 = index of the tab being renamed.
    in-out property <int> rename-idx: -1;
    in-out property <string> rename-text: "";

    callback request-activate(int);
    callback request-send-input(int, string);
    callback request-add-host(string, string, string, string);
    callback request-update-host(int, string, string, string, string);
    callback request-close-tab(int);
    callback request-new-tab();
    callback request-rename-tab(int, string);
    callback request-set-active-host(int);
    callback request-remove-host(int);
    callback open-tab-changed(int);

    changed open-tab => { root.open-tab-changed(root.open-tab) }

    fs := FocusScope {
        init => { fs.focus() }
        key-pressed(event) => {
            if event.text == Key.Escape || event.text == Key.Back {
                if root.rename-idx >= 0 {
                    root.rename-idx = -1;
                    return accept;
                }
                if root.close-confirm-idx >= 0 {
                    root.close-confirm-idx = -1;
                    return accept;
                }
                if root.editor-open {
                    root.editor-open = false;
                    return accept;
                }
                if root.picker-open {
                    root.picker-open = false;
                    return accept;
                }
                if root.open-tab >= 0 {
                    root.open-tab = -1;
                    return accept;
                }
            }
            return reject;
        }
    }

    VerticalLayout {
        spacing: 0;
        padding-top: root.safe-area-insets.top;
        padding-bottom: root.safe-area-insets.bottom;
        padding-left: root.safe-area-insets.left;
        padding-right: root.safe-area-insets.right;

        HeaderBar {
            host-name: root.hosts.length > 0 ? root.hosts[root.active-host].name : "No host";
            reachability: root.hosts.length > 0 ? root.hosts[root.active-host].reachability : "offline";
            detail: root.hosts.length > 0 ? root.hosts[root.active-host].detail : "tap + to add a workstation";
            multi-host: root.hosts.length > 1;
            host-tap => { root.picker-open = true; }
            add-host-tap => {
                root.editor-edit-index = -1;
                root.editor-name = "";
                root.editor-url = "";
                root.editor-remote-url = "";
                root.editor-token = "";
                root.editor-open = true;
            }
        }

        Rectangle {
            height: 1px;
            background: #2a2a2a;
        }

        if root.hosts.length == 0 : Rectangle {
            VerticalLayout {
                padding: 24px;
                spacing: 16px;
                alignment: center;
                Text {
                    text: "Welcome to Tab Atelier Remote";
                    color: #e0e0e0;
                    font-size: 18px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }
                Text {
                    text: "To connect to a Tab Atelier instance, open the QR code on the desktop app and scan it with your phone — or tap the + button above and enter the URL and token manually.";
                    color: #aaa;
                    font-size: 13px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }

        if root.hosts.length > 0 : Flickable {
            VerticalLayout {
                padding: 12px;
                spacing: 8px;
                for tab[i] in root.tabs : TabCard {
                    tab: tab;
                    tapped => {
                        root.open-tab = i;
                        root.request-activate(i);
                    }
                    rename-requested => {
                        root.rename-idx = i;
                        root.rename-text = tab.name;
                    }
                    close-requested => {
                        root.close-confirm-idx = i;
                        root.close-confirm-name = tab.name;
                    }
                }

                // New-tab affordance — rendered as a dashed-border card to
                // visually distinguish it from real tab rows.
                if root.tabs.length > 0 : Rectangle {
                    height: 56px;
                    background: new_ta.has-hover ? #1f2a3a : #161e2a;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #2a4060;
                    new_ta := TouchArea {
                        clicked => { root.request-new-tab() }
                        HorizontalLayout {
                            alignment: center;
                            spacing: 8px;
                            Rectangle {
                                width: 22px;
                                height: 22px;
                                y: parent.height / 2 - 11px;
                                Path {
                                    width: 22px;
                                    height: 22px;
                                    viewbox-width: 24;
                                    viewbox-height: 24;
                                    fill: #4a8cff;
                                    commands: "M 19 13 L 13 13 L 13 19 L 11 19 L 11 13 L 5 13 L 5 11 L 11 11 L 11 5 L 13 5 L 13 11 L 19 11 Z";
                                }
                            }
                            Text {
                                text: "New tab";
                                color: #4a8cff;
                                font-size: 14px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.open-tab >= 0 : TerminalView {
        width: 100%;
        height: 100%;
        tab: root.tabs[root.open-tab];
        output-text: root.open-tab-output;
        safe-top: root.safe-area-insets.top;
        safe-bottom: root.safe-area-insets.bottom;
        safe-left: root.safe-area-insets.left;
        safe-right: root.safe-area-insets.right;
        input-text <=> root.input-text;
        back => { root.open-tab = -1; }
        send-input => {
            if (root.input-text != "") {
                root.request-send-input(root.open-tab, root.input-text + "\n");
                root.input-text = "";
            }
        }
        key-tapped(k) => {
            if (k == "tab")    { root.request-send-input(root.open-tab, "\u{0009}"); }
            if (k == "esc")    { root.request-send-input(root.open-tab, "\u{001b}"); }
            if (k == "up")     { root.request-send-input(root.open-tab, "\u{001b}[A"); }
            if (k == "down")   { root.request-send-input(root.open-tab, "\u{001b}[B"); }
            if (k == "right")  { root.request-send-input(root.open-tab, "\u{001b}[C"); }
            if (k == "left")   { root.request-send-input(root.open-tab, "\u{001b}[D"); }
            if (k == "home")   { root.request-send-input(root.open-tab, "\u{001b}[H"); }
            if (k == "end")    { root.request-send-input(root.open-tab, "\u{001b}[F"); }
            if (k == "pgup")   { root.request-send-input(root.open-tab, "\u{001b}[5~"); }
            if (k == "pgdn")   { root.request-send-input(root.open-tab, "\u{001b}[6~"); }
            // Common Ctrl chords for terminal control:
            // ^C = SIGINT (0x03), ^D = EOF (0x04), ^Z = SIGTSTP (0x1a)
            if (k == "ctrl-c") { root.request-send-input(root.open-tab, "\u{0003}"); }
            if (k == "ctrl-d") { root.request-send-input(root.open-tab, "\u{0004}"); }
            if (k == "ctrl-z") { root.request-send-input(root.open-tab, "\u{001a}"); }
        }
    }

    if root.picker-open : HostPicker {
        width: 100%;
        height: 100%;
        hosts: root.hosts;
        selected-host: root.active-host;
        safe-top: root.safe-area-insets.top;
        safe-bottom: root.safe-area-insets.bottom;
        pick(i) => {
            root.active-host = i;
            root.picker-open = false;
            root.request-set-active-host(i);
        }
        edit(i) => {
            root.editor-edit-index = i;
            root.editor-name = root.hosts[i].name;
            root.editor-url = root.hosts[i].url;
            root.editor-remote-url = root.hosts[i].remote-url;
            root.editor-token = root.hosts[i].token;
            root.picker-open = false;
            root.editor-open = true;
        }
        remove(i) => {
            root.request-remove-host(i);
            if (root.hosts.length <= 1) {
                root.picker-open = false;
            }
        }
        dismiss => { root.picker-open = false; }
    }

    if root.editor-open : HostEditor {
        width: 100%;
        height: 100%;
        safe-top: root.safe-area-insets.top;
        editing: root.editor-edit-index >= 0;
        name-text <=> root.editor-name;
        url-text <=> root.editor-url;
        remote-url-text <=> root.editor-remote-url;
        token-text <=> root.editor-token;
        save(n, u, r, t) => {
            root.editor-open = false;
            if (root.editor-edit-index >= 0) {
                root.request-update-host(root.editor-edit-index, n, u, r, t);
            } else {
                root.request-add-host(n, u, r, t);
            }
        }
        dismiss => { root.editor-open = false; }
    }

    if root.rename-idx >= 0 : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000aa;
        TouchArea { clicked => { root.rename-idx = -1 } }

        Rectangle {
            width: min(parent.width * 88%, 420px);
            height: 220px;
            y: root.safe-area-insets.top + 24px;
            background: #1c1c1c;
            border-radius: 14px;
            border-width: 1px;
            border-color: #2a2a2a;

            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: 48px;
                    background: #232323;
                    border-top-left-radius: 14px;
                    border-top-right-radius: 14px;
                    Text {
                        text: "Rename tab";
                        color: #e0e0e0;
                        font-size: 16px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    padding: 16px;
                    spacing: 8px;
                    Text { text: "New name"; color: #888; font-size: 11px; }
                    Rectangle {
                        height: 40px;
                        background: #232323;
                        border-radius: 6px;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            rename-input := TextInput {
                                text <=> root.rename-text;
                                color: #e0e0e0;
                                font-size: 14px;
                                single-line: true;
                                vertical-alignment: center;
                                accepted => {
                                    if (root.rename-text != "") {
                                        root.request-rename-tab(root.rename-idx, root.rename-text);
                                    }
                                    root.rename-idx = -1;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => { root.rename-idx = -1 }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #2a2a2a : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #3a3a3a;
                            Text {
                                text: "Cancel";
                                color: #ccc;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => {
                            if (root.rename-text != "") {
                                root.request-rename-tab(root.rename-idx, root.rename-text);
                            }
                            root.rename-idx = -1;
                        }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #5599ff : #4a8cff;
                            border-radius: 6px;
                            Text {
                                text: "Rename";
                                color: white;
                                font-size: 14px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.close-confirm-idx >= 0 : Rectangle {
        width: 100%;
        height: 100%;
        background: #000000aa;
        TouchArea { clicked => { root.close-confirm-idx = -1 } }

        Rectangle {
            width: min(parent.width * 88%, 380px);
            height: 200px;
            y: parent.height / 2 - 100px;
            background: #1c1c1c;
            border-radius: 14px;
            border-width: 1px;
            border-color: #2a2a2a;

            VerticalLayout {
                padding: 0;
                spacing: 0;

                Rectangle {
                    height: 48px;
                    background: #232323;
                    border-top-left-radius: 14px;
                    border-top-right-radius: 14px;
                    Text {
                        text: "Close tab?";
                        color: #e0e0e0;
                        font-size: 16px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                VerticalLayout {
                    padding: 18px;
                    spacing: 10px;
                    alignment: center;
                    Text {
                        text: "Send DELETE /tabs/… for";
                        color: #aaa;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "\"" + root.close-confirm-name + "\"";
                        color: #f0f0f0;
                        font-size: 15px;
                        font-weight: 600;
                        font-family: "monospace";
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                }

                HorizontalLayout {
                    padding: 12px;
                    spacing: 8px;
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => { root.close-confirm-idx = -1 }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #2a2a2a : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #3a3a3a;
                            Text {
                                text: "Cancel";
                                color: #ccc;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                    TouchArea {
                        horizontal-stretch: 1;
                        clicked => {
                            root.request-close-tab(root.close-confirm-idx);
                            root.close-confirm-idx = -1;
                        }
                        Rectangle {
                            height: 40px;
                            background: parent.has-hover ? #d04545 : #ef5350;
                            border-radius: 6px;
                            Text {
                                text: "Close";
                                color: white;
                                font-size: 14px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
