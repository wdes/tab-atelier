{
  "_comment": "System-wide Claude Code hooks shipped by tab-atelier-headless. Read by `claude` for every user on this box; tab-atelier-headless's claude-hook subcommand pipes the event through to set-status (env-driven: needs TAB_ATELIER_API_URL/TOKEN/_TAB_ID exported into the PTY — tab-atelier does this automatically). Hooks fail silently if the env isn't set so a `claude` run outside any tab is unaffected.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "tab-atelier-headless claude-hook session-start" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "tab-atelier-headless claude-hook pre-tool" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "tab-atelier-headless claude-hook post-tool" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "tab-atelier-headless claude-hook notification" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "tab-atelier-headless claude-hook stop" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "tab-atelier-headless claude-hook session-end" }
        ]
      }
    ]
  }
}
