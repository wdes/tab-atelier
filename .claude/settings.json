{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/claude-lint-hook.sh",
            "timeout": 600,
            "statusMessage": "cargo fmt + clippy"
          }
        ]
      }
    ]
  }
}
