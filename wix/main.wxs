<?xml version="1.0" encoding="windows-1252"?>
<!--
  WiX 3 source for the tab-atelier-headless MSI.

  Built on a Windows runner by .github/workflows/windows-msi.yml, which
  pre-builds tab-atelier-headless and happier-relay (the headless plus
  happier-bridge feature set only; catbus and energy are Linux-only,
  being /proc plus AF_UNIX and /sys powercap respectively), then
  packages them with cargo-wix in no-build mode so this MSI ships just
  the two cross-platform binaries.

  This v1 installs the binaries to Program Files and puts the folder on
  the system PATH. Running the daemon as a Windows Service (the analogue
  of the systemd unit) is a follow-up: tab-atelier-headless is a plain
  console app today and would need SCM integration first.

  cargo-wix supplies the preprocessor variables used below:
    $(var.Version) is the product version (the workflow overrides it);
    $(var.CargoTargetBinDir) is the directory holding the built exe files.
  NOTE: XML comments must not contain a double hyphen, so flag names are
  spelled out in prose here rather than written literally.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="tab-atelier-headless"
    UpgradeCode="de89554f-ff28-4a56-bed7-3c3319c0c2ea"
    Language="1033"
    Codepage="1252"
    Version="$(var.Version)"
    Manufacturer="William Desportes">

    <Package
      Id="*"
      Keywords="Installer"
      Description="tab-atelier headless tab daemon"
      Manufacturer="William Desportes"
      InstallerVersion="450"
      Languages="1033"
      Compressed="yes"
      InstallScope="perMachine"
      SummaryCodepage="1252" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of tab-atelier-headless is already installed. Setup will now exit." />

    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="APPLICATIONFOLDER" Name="tab-atelier">
          <Component Id="HeadlessExe" Guid="*">
            <File
              Id="TabAtelierHeadlessExe"
              Name="tab-atelier-headless.exe"
              Source="$(var.CargoTargetBinDir)\tab-atelier-headless.exe"
              KeyPath="yes" />
          </Component>
          <Component Id="RelayExe" Guid="*">
            <File
              Id="HappierRelayExe"
              Name="happier-relay.exe"
              Source="$(var.CargoTargetBinDir)\happier-relay.exe"
              KeyPath="yes" />
          </Component>
          <!-- Put the install dir on the system PATH so both binaries
               are runnable from any terminal. Needs an explicit GUID:
               it has no File keypath (Environment + CreateFolder only),
               so WiX cannot auto-generate one. -->
          <Component Id="PathEntry" Guid="eccf247c-a6cd-4fbb-9c34-6dc02c56863f">
            <CreateFolder />
            <Environment
              Id="UpdatePath"
              Name="PATH"
              Value="[APPLICATIONFOLDER]"
              Permanent="no"
              Part="last"
              Action="set"
              System="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="tab-atelier-headless" Level="1">
      <ComponentRef Id="HeadlessExe" />
      <ComponentRef Id="RelayExe" />
      <ComponentRef Id="PathEntry" />
    </Feature>
  </Product>
</Wix>
