<?xml version="1.0" encoding="windows-1252"?>
<!--
  WiX 3 source for the tab-atelier-headless MSI.

  Built on a Windows runner by .github/workflows/windows-msi.yml, which
  pre-builds tab-atelier-headless (headless feature only; catbus and
  energy are Linux-only, being /proc plus AF_UNIX and /sys powercap
  respectively) then packages it with cargo-wix in no-build mode so
  this MSI ships just the one cross-platform binary.

  This v1 installs the binaries to Program Files and puts the folder on
  the system PATH. Running the daemon as a Windows Service (the analogue
  of the systemd unit) is a follow-up: tab-atelier-headless is a plain
  console app today and would need SCM integration first.

  cargo-wix supplies the preprocessor variables used below:
    $(var.Version) is the product version (the workflow overrides it);
    $(var.CargoTargetBinDir) is the directory holding the built exe files.
  NOTE: XML comments must not contain a double hyphen, so flag names are
  spelled out in prose here rather than written literally.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="tab-atelier-headless"
    UpgradeCode="de89554f-ff28-4a56-bed7-3c3319c0c2ea"
    Language="1033"
    Codepage="1252"
    Version="$(var.Version)"
    Manufacturer="William Desportes">

    <Package
      Id="*"
      Keywords="Installer"
      Description="tab-atelier headless tab daemon"
      Manufacturer="William Desportes"
      InstallerVersion="450"
      Languages="1033"
      Compressed="yes"
      InstallScope="perMachine"
      SummaryCodepage="1252" />

    <MajorUpgrade
      Schedule="afterInstallInitialize"
      DowngradeErrorMessage="A newer version of tab-atelier-headless is already installed. Setup will now exit." />

    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="APPLICATIONFOLDER" Name="tab-atelier">
          <Component Id="HeadlessExe" Guid="*">
            <File
              Id="TabAtelierHeadlessExe"
              Name="tab-atelier-headless.exe"
              Source="$(var.CargoTargetBinDir)\tab-atelier-headless.exe"
              KeyPath="yes" />
            <!-- Register + run as a background Windows service (no
                 console window). The exe detects the SCM launch via
                 win_service.rs and runs under the dispatcher.

                 Runs as the built-in low-privilege LocalService account
                 (the Windows analogue of the Linux service user) rather
                 than LocalSystem: no password, no account to create, and
                 it already holds the "log on as a service" right. Its
                 per-service profile under
                 C:\Windows\ServiceProfiles\LocalService backs the
                 %APPDATA% / %USERPROFILE% paths the daemon writes to. -->
            <ServiceInstall
              Id="HeadlessServiceInstall"
              Name="tab-atelier-headless"
              DisplayName="tab-atelier headless tab daemon"
              Description="Restores tabs and serves the local HTTP/TLS API."
              Type="ownProcess"
              Start="auto"
              ErrorControl="normal"
              Account="NT AUTHORITY\LocalService"
              Vital="yes" />
            <ServiceControl
              Id="HeadlessServiceControl"
              Name="tab-atelier-headless"
              Start="install"
              Stop="both"
              Remove="uninstall"
              Wait="yes" />
          </Component>
          <!-- Put the install dir on the system PATH so the binary
               is runnable from any terminal. Needs an explicit GUID:
               this component has no File keypath (Environment +
               CreateFolder only), so WiX cannot auto-generate one. -->
          <Component Id="PathEntry" Guid="eccf247c-a6cd-4fbb-9c34-6dc02c56863f">
            <CreateFolder />
            <Environment
              Id="UpdatePath"
              Name="PATH"
              Value="[APPLICATIONFOLDER]"
              Permanent="no"
              Part="last"
              Action="set"
              System="yes" />
          </Component>
        </Directory>
      </Directory>

      <!-- Start Menu entry. A .url Internet Shortcut (installed as a
           plain file) opens the local API in the default browser, so
           there is a Programs entry that doesn't pop a console window
           the way launching the daemon exe directly does. -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="tab-atelier">
          <!-- Explicit GUID required: this component mixes a File and a
               RegistryValue keypath, so WiX can't auto-generate one. -->
          <Component Id="StartMenuShortcut" Guid="9d507611-ade1-4318-9a76-2d975fd3b4ad">
            <File
              Id="TabAtelierUrl"
              Name="tab-atelier.url"
              Source="assets\windows\tab-atelier.url" />
            <RemoveFolder Id="RemoveAppMenuFolder" On="uninstall" />
            <!-- ICE38: a component installing into the user profile
                 (Start Menu) must use an HKCU registry value as its
                 KeyPath, not the file. Standard WiX shortcut pattern. -->
            <RegistryValue
              Root="HKCU"
              Key="Software\tab-atelier"
              Name="StartMenuShortcut"
              Type="integer"
              Value="1"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="tab-atelier-headless" Level="1">
      <ComponentRef Id="HeadlessExe" />
      <ComponentRef Id="PathEntry" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Product>
</Wix>
